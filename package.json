{
  "name": "tawtui",
  "version": "0.2.0",
  "description": "A TUI on top of Taskwarrior for task management and PR review",
  "author": "Alfonso Emilio Gomez Selva <stein.hakase.vs@gmail.com>",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/victorstein/tawtui.git"
  },
  "license": "MIT",
  "bin": {
    "tawtui": "./src/main.ts"
  },
  "scripts": {
    "build": "bunx tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "bun run src/main.ts",
    "start:dev": "bun run --watch src/main.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "build:release": "./scripts/build-release.sh",
    "build:notify": "./src/notify-helper/build.sh"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@anthropic-ai/claude-agent-sdk": "^0.3.185",
    "@opentui/core": "^0.1.79",
    "@opentui/solid": "^0.1.79",
    "nest-commander": "^3.20.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bun": "^1.3.9",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts",
      "tsx"
    ],
    "rootDir": ".",
    "testRegex": "test/.*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "transform": {
      "^.+\\.(t|j)sx?$": ["ts-jest", {
        "tsconfig": "tsconfig.jest.json"
      }]
    },
    "moduleNameMapper": {
      "^@opentui/solid$": "<rootDir>/test/__mocks__/opentui-solid.ts",
      "^@opentui/core$": "<rootDir>/test/__mocks__/empty-module.ts",
      "^solid-js$": "<rootDir>/test/__mocks__/solid-js.ts",
      "^solid-js/(.*)$": "<rootDir>/test/__mocks__/solid-js.ts",
      "^react/jsx-runtime$": "<rootDir>/test/__mocks__/react-jsx-runtime.ts",
      "\\.\/tui\\/app$": "<rootDir>/test/__mocks__/empty-module.ts"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  }
}
